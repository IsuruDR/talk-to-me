  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/talk-to-me.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
